# ============================================
# 租户环境变量模板
# Tenant Environment Template
# ============================================

# 租户基本信息
TENANT_ID=tenant001
TENANT_NAME=Default Tenant
TENANT_TIER=starter

# 数据库配置
TENANT_DB=tenant_${TENANT_ID}
TENANT_USER=tenant_${TENANT_ID}_user
TENANT_PASSWORD=CHANGE_ME

# Redis 配置
TENANT_REDIS_PASSWORD=CHANGE_ME
TENANT_REDIS_MAXMEMORY=512mb

# 资源配额
TENANT_CPU_LIMIT=2
TENANT_MEM_LIMIT=4g
TENANT_PIDS_LIMIT=100
TENANT_DISK_QUOTA=20g

# 沙盒资源配置
TENANT_SANDBOX_CPU=2
TENANT_SANDBOX_MEM=8g

# 速率限制
TENANT_RATE_LIMIT=1000
TENANT_BURST=100
