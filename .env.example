#===========================================
# Agent Teams Manager - Environment Config
#===========================================

# Project
PROJECT_NAME=agent-teams-manager

# Deploy Mode: cloud | local
# cloud = 前端 + 监控完整功能
# local = 仅 Teams 核心服务
DEPLOY_MODE=cloud

#========== 数据库配置 ==========
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=agent_teams
PG_USER=postgres
PG_PASSWORD=your_secure_password

#========== Redis ==========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

#========== ChromaDB (RAG) ==========
CHROMA_HOST=localhost
CHROMA_PORT=8000

#========== 服务器配置 ==========
SERVER_PORT=3001
NODE_ENV=production

#========== 前端配置 ==========
FRONTEND_PORT=80
API_URL=https://api.your-domain.com
CORS_ORIGIN=https://your-domain.com

#========== Cloudflare Tunnel (本地部署用) ==========
# Cloudflare Tunnel 域名 (留空则使用随机域名)
# TUNNEL_DOMAIN=your-domain.com
# Tunnel 名称
TUNNEL_NAME=agent-teams

#========== SSL 配置 (可选) ==========
# 使用 Let's Encrypt 自动 HTTPS
# FRONTEND_HTTPS_PORT=443
