#===========================================
# Agent Teams Manager - Environment Config
#===========================================

# Project
PROJECT_NAME=agent-teams-manager

# Deploy Mode: cloud | local
# cloud = 前端 + 监控完整功能
# local = 仅 Teams 核心服务
DEPLOY_MODE=cloud

# Domain (required for SSL)
DOMAIN=ai.example.com

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=agent_teams
PG_USER=postgres
PG_PASSWORD=your_secure_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Server
SERVER_PORT=3001
NODE_ENV=production

# Frontend (SSL)
FRONTEND_HTTP_PORT=80
FRONTEND_HTTPS_PORT=443
API_URL=https://api.example.com
CORS_ORIGIN=https://ai.example.com

# Docker Registry (optional, for remote deployment)
DOCKER_REGISTRY=
