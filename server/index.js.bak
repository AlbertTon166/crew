// Graceful shutdown
process.on('SIGTERM', async () => {
  console.log('Received SIGTERM, shutting down...')
  await closeAllDatabases()
  process.exit(0)
})

// Start server
app.listen(PORT, () => {
  console.log(`🚀 Agent Teams Server running on port ${PORT}`)
  console.log(`   PostgreSQL: ${process.env.PG_HOST || 'localhost'}:${process.env.PG_PORT || 5432}`)
  console.log(`   Redis: ${process.env.REDIS_HOST || 'localhost'}:${process.env.REDIS_PORT || 6379}`)
  console.log(`   ChromaDB: ${process.env.CHROMA_HOST || 'localhost'}:${process.env.CHROMA_PORT || 8000}`)
})
