// ==================== Dashboard APIs ====================

app.get('/api/dashboard/stats', async (req, res) => {
  try {
    const db = getPgPool()
    
    const projects = await db.query('SELECT status, COUNT(*) as count FROM projects GROUP BY status')
    const tasks = await db.query('SELECT status, COUNT(*) as count FROM tasks GROUP BY status')
    const agents = await db.query('SELECT role, status, COUNT(*) as count FROM agents GROUP BY role, status')
    
    const stats = {
      totalProjects: projects.rows.reduce((sum, r) => sum + parseInt(r.count), 0),
      projectStats: projects.rows,
      taskStats: tasks.rows,
      agentStats: agents.rows,
    }
    
    res.json(stats)
  } catch (error) {
    // Fallback to mock data if DB not ready
    res.json({
      totalProjects: 5,
      projectStats: [],
      taskStats: [],
      agentStats: [],
    })
  }
})

// ==================== Project APIs ====================

app.get('/api/projects', async (req, res) => {
  try {
    const db = getPgPool()
    const result = await db.query('SELECT * FROM projects ORDER BY created_at DESC')
    res.json(result.rows)
  } catch (error) {
    res.json([])
  }
})

app.post('/api/projects', async (req, res) => {
  try {
    const db = getPgPool()
    const { name, description, githubRepo, githubToken } = req.body
    const result = await db.query(
      `INSERT INTO projects (name, description, github_repo, github_token) 
       VALUES ($1, $2, $3, $4) RETURNING *`,
      [name, description, githubRepo, githubToken]
    )
    res.json(result.rows[0])
  } catch (error) {
    res.status(500).json({ error: error.message })
  }
})

app.put('/api/projects/:id', async (req, res) => {
  try {
    const db = getPgPool()
    const { id } = req.params
    const { name, description, status, githubRepo, githubToken } = req.body
    const result = await db.query(
      `UPDATE projects SET 
        name = COALESCE($1, name), 
        description = COALESCE($2, description),
        status = COALESCE($3, status),
        github_repo = COALESCE($4, github_repo),
        github_token = COALESCE($5, github_token),
        updated_at = NOW()
       WHERE id = $6 RETURNING *`,
      [name, description, status, githubRepo, githubToken, id]
    )
    res.json(result.rows[0])
  } catch (error) {
    res.status(500).json({ error: error.message })
  }
})

// ==================== Team Template APIs ====================

app.get('/api/templates', (req, res) => {
  res.json(TEAM_TEMPLATES)
})

app.get('/api/templates/recommended', (req, res) => {
  const { projectType } = req.query
  const templates = getRecommendedTemplates(projectType || '')
  res.json(templates)
})

app.get('/api/templates/:id', (req, res) => {
  const template = TEAM_TEMPLATES.find(t => t.id === req.params.id)
  if (!template) {
    return res.status(404).json({ error: 'Template not found' })
  }
  res.json({
    ...template,
    teamSize: calculateTeamSize(template),
    roleDistribution: getRoleDistribution(template),
  })
})

app.post('/api/projects/:projectId/apply-template', async (req, res) => {
  try {
    const db = getPgPool()
    const { projectId } = req.params
    const { templateId } = req.body
    
    const template = TEAM_TEMPLATES.find(t => t.id === templateId)
    if (!template) {
      return res.status(404).json({ error: 'Template not found' })
    }
    
    const agents = []
    
    // Create agents based on template
    for (const roleConfig of template.agents) {
      for (let i = 0; i < roleConfig.count; i++) {
        const agentId = crypto.randomUUID()
        const agentName = `${roleConfig.role.toUpperCase()}-${i + 1}`
        
        await db.query(
          `INSERT INTO agents (id, name, role, status, model_provider, model_name, skills, enabled)
           VALUES ($1, $2, $3, 'offline', 'openai', 'gpt-4', $4, true)`,
          [agentId, agentName, roleConfig.role, roleConfig.skills || []]
        )
        
        agents.push({
          id: agentId,
          name: agentName,
          role: roleConfig.role,
          skills: roleConfig.skills,
        })
      }
    }
    
    res.json({
      success: true,
      template: template.name,
      teamSize: calculateTeamSize(template),
      agents,
    })
  } catch (error) {
    res.status(500).json({ error: error.message })
  }
})

// ==================== Task APIs ====================

app.get('/api/projects/:projectId/tasks', async (req, res) => {
  try {
    const db = getPgPool()
    const { projectId } = req.params
    const result = await db.query(
      'SELECT * FROM tasks WHERE project_id = $1 ORDER BY created_at ASC',
      [projectId]
    )
    res.json(result.rows)
  } catch (error) {
    res.json([])
  }
})

app.post('/api/tasks/:taskId/execute', async (req, res) => {
  try {
    const { taskId } = req.params
    const db = getPgPool()
    
    // Get task details
    const task = await db.query('SELECT * FROM tasks WHERE id = $1', [taskId])
    if (!task.rows[0]) {
      return res.status(404).json({ error: 'Task not found' })
    }
    
    // Simulate task execution
    const executionId = crypto.randomUUID()
    const startedAt = new Date().toISOString()
    
    // Create execution log
    await db.query(
      `INSERT INTO execution_logs (id, task_id, status, started_at) 
       VALUES ($1, $2, 'running', $3)`,
      [executionId, taskId, startedAt]
    )
    
    // Update task
    await db.query(
      `UPDATE tasks SET execution_count = execution_count + 1, updated_at = NOW() WHERE id = $1`,
      [taskId]
    )
    
    res.json({ executionId, taskId, status: 'started' })
  } catch (error) {
    res.status(500).json({ error: error.message })
  }
})

