  }
})

app.get('/api/sessions/:sessionId', async (req, res) => {
  try {
    const { sessionId } = req.params
    const { getSession } = await import('./databases.js')
    const session = await getSession(sessionId)
    res.json(session || null)
  } catch (error) {
