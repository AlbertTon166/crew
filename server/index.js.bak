/**
 * Agent Teams Manager - Backend Server
 * 
 * PostgreSQL: 结构化数据
 * Redis: 缓存/会话/实时
 * ChromaDB: 向量知识库
 * Docker: 部署自动化
 */

import express from 'express'
import cors from 'cors'
import { initAllDatabases, closeAllDatabases, getPgPool, getRedis, getChroma, cacheSet, cacheGet } from './databases.js'
import { 
  deployApplication, 
  undeployApplication, 
  getDeploymentStatus,
  checkDocker,
  checkDockerCompose 
} from './docker.js'
import { TEAM_TEMPLATES, getRecommendedTemplates, calculateTeamSize, getRoleDistribution } from './team-templates.js'

const app = express()
const PORT = process.env.PORT || 3001

app.use(cors())
app.use(express.json())

// Initialize databases on startup
initAllDatabases().catch(console.error)

// Health check
app.get('/api/health', (req, res) => {
  res.json({ 
    status: 'ok', 
    timestamp: new Date().toISOString(),
    services: {
      postgres: 'connected',
      redis: 'connected', 
      chromadb: 'connected'
    }
  })
})

// ==================== Docker/Deployment APIs ====================

app.get('/api/docker/status', async (req, res) => {
  const docker = await checkDocker()
  const compose = await checkDockerCompose()
  res.json({ docker, compose })
})

app.post('/api/deploy', async (req, res) => {
  try {
    const { projectId, projectName, frontend, backend } = req.body
    
    const result = await deployApplication({
      projectId,
      projectName,
      frontend,
      backend,
      network: `${projectName}-network`,
      onProgress: (step, details) => {
        console.log(`[DEPLOY] ${step}`, details || '')
      }
    })
    
    if (result.success) {
      // Cache deployment info
      await cacheSet(`deployment:${projectId}`, result, 86400)
    }
    
    res.json(result)
  } catch (error) {
    res.status(500).json({ success: false, error: error.message })
  }
})

app.delete('/api/deploy/:projectName', async (req, res) => {
  try {
    const { projectName } = req.params
    const result = await undeployApplication(projectName)
    res.json(result)
  } catch (error) {
    res.status(500).json({ success: false, error: error.message })
  }
})

app.get('/api/deploy/:projectName/status', async (req, res) => {
  try {
    const { projectName } = req.params
    const status = await getDeploymentStatus(projectName)
    res.json(status)
  } catch (error) {
    res.status(500).json({ success: false, error: error.message })
  }
})

// ==================== Knowledge Base APIs (ChromaDB) ====================

app.post('/api/knowledge', async (req, res) => {
  try {
    const { title, content, metadata } = req.body
    const { addKnowledge } = await import('./databases.js')
    const id = await addKnowledge(title, content, metadata)
    res.json({ success: true, id })
  } catch (error) {
    res.status(500).json({ success: false, error: error.message })
  }
})

app.get('/api/knowledge/search', async (req, res) => {
  try {
    const { q, topK = 3 } = req.query
    const { searchKnowledge } = await import('./databases.js')
    const results = await searchKnowledge(q, topK)
    res.json(results)
  } catch (error) {
    res.status(500).json({ success: false, error: error.message })
  }
})

