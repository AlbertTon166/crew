# Crew Backend Environment Configuration

# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=604800

# PostgreSQL
PGHOST=localhost
PGPORT=5432
PGDATABASE=crew
PGUSER=postgres
PGPASSWORD=postgres
PGMAX=20
PGIDLE_TIMEOUT=30000
PGCONNECTION_TIMEOUT=2000

# CORS
CORS_ORIGIN=*
CORS_CREDENTIALS=false

# Logging
LOG_LEVEL=info
